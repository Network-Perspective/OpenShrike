{
  "name": "openshrike",
  "version": "0.2.2",
  "private": true,
  "description": "Security-first agentic code reviewer and best-practice auditor built on OpenCode.",
  "type": "module",
  "bin": {
    "shrike": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node22 --clean",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:prepare": "scripts/create-release.sh"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-scroll-view": "^0.3.6",
    "opencode-ai": "^1.3.0",
    "react": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.1"
  }
}
