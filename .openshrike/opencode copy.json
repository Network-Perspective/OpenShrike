{
  "$schema": "https://opencode.ai/config.json",
  "model": "azure/gpt-5.4-mini",
  "provider": {
    "azure": {
      "env": [
        "AZURE_OPENAI_API_KEY",
        "OPENSHRIKE_AZURE_OPENAI_BASE_URL",
        "OPENSHRIKE_AZURE_OPENAI_API_VERSION"
      ],
      "options": {
        "apiKey": "${AZURE_OPENAI_API_KEY}",
        "baseURL": "${OPENSHRIKE_AZURE_OPENAI_BASE_URL}",
        "queryParams": {
          "api-version": "${OPENSHRIKE_AZURE_OPENAI_API_VERSION}"
        }
      },
      "models": {
        "gpt-5.4-mini": {
          "name": "gpt-5.4-mini"
        }
      }
    }
  },
  "permission": {
    "bash": "allow",
    "edit": "deny",
    "webfetch": "deny",
    "doom_loop": "deny",
    "external_directory": "deny"
  },
  "agent": {
    "shrike-checker": {
      "description": "Runs OpenShrike checks in a read-only review session.",
      "model": "azure/gpt-5.4-mini",
      "permission": {
        "bash": "allow",
        "edit": "deny",
        "webfetch": "deny",
        "doom_loop": "deny",
        "external_directory": "deny"
      }
    }
  }
}
