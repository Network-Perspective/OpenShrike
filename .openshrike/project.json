{
  "$schema": "https://openshrike.dev/schema/project.json",
  "version": 1,
  "init": {
    "projectType": "typescript",
    "detectedFrom": [
      "tsconfig.json",
      "package.json",
      "src/**/*.ts"
    ],
    "opencodeSetup": "existing-config",
    "seedPolicyId": "typescript-baseline"
  },
  "runtime": {
    "configPath": ".openshrike/opencode.json",
    "agent": "shrike-checker",
    "model": "azure/gpt-5.4-mini",
    "mode": "docker",
    "parallelism": "auto"
  },
  "scan": {
    "defaultKind": "project-checks",
    "defaultId": ".openshrike/checks",
    "repo": ".",
    "scope": "uncommitted",
    "output": "markdown",
    "ui": true,
    "artifactsDir": null
  }
}
