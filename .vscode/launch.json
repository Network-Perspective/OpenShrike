{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "OpenShrike Mockup",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/vscode/**/*.cjs"
      ],
      "preLaunchTask": "npm: build:extension"
    }
  ]
}
